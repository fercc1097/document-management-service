# Copy to `.env` and override for non-dev environments.
# The compose file ships dev defaults, so `docker-compose up --build` works out of the
# box without this file. Never commit real secrets — override them via the environment.

POSTGRES_USER=appuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=challenge

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=document-bucket
